#!/bin/bash

# ===============================
# Argument
# ===============================
URL="$1"

# ===============================
# Validate input
# ===============================
if [ -z "$URL" ]; then
    echo "Usage: showformat <url>"
    exit 1
fi

# ===============================
# Check dependency
# ===============================
if ! command -v yt-dlp >/dev/null 2>&1; then
    echo "yt-dlp not found. Install it using:"
    echo "  sudo apt install yt-dlp"
    exit 1
fi

# ===============================
# Show available formats
# ===============================
yt-dlp --list-formats "$URL"